<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FocusFlow.ViewModels"
             x:Class="FocusFlow.Views.TaskListView"
             x:DataType="vm:TaskListViewModel">
	<DockPanel Margin="15">
		<!-- Заголовок блока "Задачи" -->
		<TextBlock DockPanel.Dock="Top" Text="{Binding Loc[Tasks]}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#111827"/>

		<!-- Панель фильтров приоритетов -->
		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
			<Button Content="{Binding Loc[FilterAll]}" Background="#E5E7EB"/>
			<Button Content="{Binding Loc[FilterHigh]}" Background="#FEE2E2" Foreground="#DC2626"/>
			<Button Content="{Binding Loc[FilterMedium]}" Background="#FEF3C7" Foreground="#D97706"/>
		</StackPanel>

		<!-- Список задач (Оставляем вашу текущую реализацию DataGrid или ItemsControl) -->
		<ListBox ItemsSource="{Binding Tasks}">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding Title}"/>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</DockPanel>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FocusFlow.ViewModels"
        xmlns:services="using:FocusFlow.Services"
        x:Class="FocusFlow.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{Binding Loc[Settings]}" Width="600" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">

	<Window.Styles>
		<Style Selector="Border.Card">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="Padding" Value="16,12"/>
			<Setter Property="Margin" Value="0,0,0,12"/>
			<Setter Property="BorderBrush" Value="#E5E7EB"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="*, 60">
		<Grid Grid.Row="0" ColumnDefinitions="180, *">

			<!-- ЛЕВОЕ ВЕРТИКАЛЬНОЕ МЕНЮ -->
			<Border Grid.Column="0" Background="#EEF2F6" Padding="12">
				<StackPanel Spacing="5">
					<TextBlock Text="{Binding Loc[Settings]}" FontSize="18" FontWeight="Bold" Foreground="#1E3A8A" Margin="8,10,0,20"/>
					<ToggleButton Content="{Binding Loc[General]}" IsChecked="{Binding IsGeneralTab}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10"/>
					<ToggleButton Content="{Binding Loc[Notifications]}" IsChecked="{Binding IsNotificationsTab}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10"/>
					<ToggleButton Content="{Binding Loc[Hotkeys]}" IsChecked="{Binding IsHotkeysTab}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10"/>
					<ToggleButton Content="{Binding Loc[Data]}" IsChecked="{Binding IsDataTab}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="12,10"/>
				</StackPanel>
			</Border>

			<!-- ЦЕНТРАЛЬНЫЙ КОНТЕНТ -->
			<ScrollViewer Grid.Column="1" Padding="24">
				<Panel>
					<!-- 1. ОБЩИЕ -->
					<StackPanel Spacing="15" IsVisible="{Binding IsGeneralTab}">
						<TextBlock Text="{Binding Loc[Appearance]}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="14"/>
						<Grid ColumnDefinitions="*, *, *">
							<ToggleButton Grid.Column="0" Content="{Binding Loc[LightTheme]}" IsChecked="{Binding OptLightTheme}" Margin="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
							<ToggleButton Grid.Column="1" Content="{Binding Loc[DarkTheme]}" IsChecked="{Binding OptDarkTheme}" Margin="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
							<ToggleButton Grid.Column="2" Content="{Binding Loc[AutoTheme]}" IsChecked="{Binding OptAutoTheme}" Margin="4" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
						</Grid>
						<TextBlock Text="{Binding Loc[LangRegion]}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="14" Margin="0,15,0,0"/>

						<!-- ИСПРАВЛЕНО: Привязка через SelectedIndex гарантирует стабильность сборки XAML -->
						<ComboBox SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
							<ComboBoxItem Content="Русский"/>
							<ComboBoxItem Content="English"/>
						</ComboBox>
					</StackPanel>

					<!-- 2. УВЕДОМЛЕНИЯ -->
					<StackPanel IsVisible="{Binding IsNotificationsTab}">
						<TextBlock Text="{Binding Loc[Notifications]}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="14" Margin="0,0,0,15"/>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, Auto">
								<StackPanel Grid.Column="0">
									<TextBlock Text="{Binding Loc[SysNotif]}" FontWeight="SemiBold"/>
									<TextBlock Text="{Binding Loc[SysNotifSub]}" FontSize="11" Foreground="#9CA3AF"/>
								</StackPanel>
								<ToggleSwitch Grid.Column="1" IsChecked="{Binding SystemNotifications}"/>
							</Grid>
						</Border>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, Auto">
								<StackPanel Grid.Column="0">
									<TextBlock Text="{Binding Loc[SoundNotif]}" FontWeight="SemiBold"/>
									<TextBlock Text="{Binding Loc[SoundNotifSub]}" FontSize="11" Foreground="#9CA3AF"/>
								</StackPanel>
								<ToggleSwitch Grid.Column="1" IsChecked="{Binding SoundNotifications}"/>
							</Grid>
						</Border>
					</StackPanel>

					<!-- 3. ГОРЯЧИЕ КЛАВИШИ -->
					<StackPanel IsVisible="{Binding IsHotkeysTab}">
						<TextBlock Text="{Binding Loc[Hotkeys]}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="14" Margin="0,0,0,15"/>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, 120">
								<TextBlock Grid.Column="0" Text="{Binding Loc[SwitchToDay]}" VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Text="{Binding HotkeyDay, Mode=TwoWay}" KeyDown="Hotkey_KeyDown" Watermark="Нажмите клавиши" HorizontalContentAlignment="Center" Background="#EFF6FF" Foreground="#2563EB" FontWeight="Bold"/>
							</Grid>
						</Border>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, 120">
								<TextBlock Grid.Column="0" Text="{Binding Loc[SwitchToWeek]}" VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Text="{Binding HotkeyWeek, Mode=TwoWay}" KeyDown="Hotkey_KeyDown" Watermark="Нажмите клавиши" HorizontalContentAlignment="Center" Background="#EFF6FF" Foreground="#2563EB" FontWeight="Bold"/>
							</Grid>
						</Border>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, 120">
								<TextBlock Grid.Column="0" Text="{Binding Loc[NewTask]}" VerticalAlignment="Center"/>
								<TextBox Grid.Column="1" Text="{Binding HotkeyNewTask, Mode=TwoWay}" KeyDown="Hotkey_KeyDown" Watermark="Нажмите клавиши" HorizontalContentAlignment="Center" Background="#EFF6FF" Foreground="#2563EB" FontWeight="Bold"/>
							</Grid>
						</Border>
					</StackPanel>

					<!-- 4. ДАННЫЕ -->
					<StackPanel IsVisible="{Binding IsDataTab}">
						<TextBlock Text="{Binding Loc[ExportData]}" FontWeight="Bold" Foreground="#1E3A8A" FontSize="14" Margin="0,0,0,15"/>
						<Border Classes="Card">
							<Grid ColumnDefinitions="*, Auto">
								<StackPanel Grid.Column="0">
									<TextBlock Text="{Binding Loc[Backup]}" FontWeight="SemiBold"/>
									<TextBlock Text="{Binding Loc[BackupSub]}" FontSize="11" Foreground="#9CA3AF"/>
								</StackPanel>
								<Button Grid.Column="1" Content="{Binding Loc[ExportBtn]}" Command="{Binding ExportDataCommand}" Background="#3B82F6" Foreground="White"/>
							</Grid>
						</Border>
						<Border BorderBrush="#FEE2E2" BorderThickness="1" Background="#FEF2F2" CornerRadius="8" Padding="16,12">
							<StackPanel Spacing="8">
								<TextBlock Text="{Binding Loc[DangerZone]}" FontWeight="Bold" Foreground="#DC2626"/>
								<TextBlock Text="{Binding Loc[ClearSub]}" FontSize="11" Foreground="#EF4444"/>
								<Button Content="{Binding Loc[ClearBtn]}" Command="{Binding ClearDataCommand}" Background="#EF4444" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
							</StackPanel>
						</Border>
					</StackPanel>
				</Panel>
			</ScrollViewer>
		</Grid>

		<!-- НИЖНЯЯ ПАНЕЛЬ С КНОПКАМИ -->
		<Border Grid.Row="1" Background="#EEF2F6" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,0">
			<Grid ColumnDefinitions="*, Auto, Auto" VerticalAlignment="Center">
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
					<Button Content="{Binding Loc[Close]}" Command="{Binding CancelCommand}" Width="100" HorizontalContentAlignment="Center" Background="White" BorderBrush="#D1D5DB" BorderThickness="1"/>
					<Button Content="{Binding Loc[Save]}" Command="{Binding SaveCommand}" Width="110" HorizontalContentAlignment="Center" Background="#3B82F6" Foreground="White"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>
